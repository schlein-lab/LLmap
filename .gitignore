# Secrets — never commit
.env
.env.local
*.key
*.pem
anthropic_api_key
SCHLEIN_LAB_TOKEN

# Claude-generated artifacts (audit log only, not the kernels themselves)
generated_kernels/*.so
generated_kernels/*.cu
